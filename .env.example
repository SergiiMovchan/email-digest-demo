# Copy this file to .env and fill in real values.
# .env is git-ignored (see .gitignore).

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=          # private group id, negative number, e.g. -100XXXXXXXXXX

# Anthropic (Claude) API
ANTHROPIC_API_KEY=

# IMAP mailbox passwords (use app-passwords, not the main account password)
IMAP_PASSWORD_1=
IMAP_PASSWORD_2=
